a = input('Digite algo: ')
print('Qual o tipo primitivo do valor digitado?',type(a))
print('Esse valor é numeric?',a.isnumeric())
print('Esse valor é alphabetic?',a.isalpha())
print('Esse valor é alphanumeric?',a.isalnum())
print('Esse valor esta capitalizado?', a.istitle())
print('Esse valor se classifica como upper?',a.isupper())
print('Esse valor se classifica com lower?',a.islower())
print('Esse valor possou somente espaços?',a.isspace())
